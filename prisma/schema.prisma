generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RiskLevel {
  HIGH
  MEDIUM
  LOW
}

enum AlertType {
  HEART_RATE_SURGE
  VOICE_TREMOR
  SLEEP_ANOMALY
  EMOTION_SWING
  SOCIAL_WITHDRAWAL
  GAIT_ANOMALY
  EATING_ANOMALY
}

enum WorkOrderStatus {
  PENDING      // 待处理（高危列表，未指派咨询师）
  IN_PROGRESS  // 干预中（干预记录，已指派咨询师）
  COMPLETED    // 已完成
}

enum InterventionType {
  REGULAR_INTERVIEW
  CBT_THERAPY
  GROUP_COUNSELING
  CRISIS_INTERVENTION
  INITIAL_ASSESSMENT
}

enum DeviceType {
  VR
  BRACELET
  EEG
}

enum DeviceStatus {
  ONLINE
  OFFLINE
  IN_USE
  MAINTENANCE
}

enum RoomStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
}

enum Sentiment {
  POSITIVE
  NEGATIVE
  NEUTRAL
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum CommentStatus {
  ACTIVE
  HIDDEN
  DELETED
}

enum MessageStatus {
  SENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum SessionStatus {
  ACTIVE
  CLOSED
  ARCHIVED
}

enum DocStatus {
  VECTORIZED
  PROCESSING
  FAILED
}
model Student {
  id                  String               @id @default(uuid())
  name                String
  studentNo           String               @unique @map("student_no")
  className           String               @map("class_name")
  facultyId           String?              @map("faculty_id")
  gender              String?
  birthDate           DateTime?            @map("birth_date")
  mbti                String?
  riskLevel           RiskLevel            @default(LOW) @map("risk_level")
  // 小程序扩展字段
  phone               String?              @unique
  passwordHash        String?              @map("password_hash")
  avatar              String?
  nickname            String?
  role                String               @default("student")
  status              StudentStatus        @default(ACTIVE)
  badges              Json?
  stats               Json?
  settings            Json?
  lastLoginAt         DateTime?            @map("last_login_at")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  faculty             Faculty?             @relation(fields: [facultyId], references: [id])
  psychProfile        PsychProfile?
  timelineEvents      TimelineEvent[]
  alerts              Alert[]
  workOrders          WorkOrder[]
  interventionRecords InterventionRecord[]
  vrSessions          VRSession[]
  vitalSigns          VitalSign[]
  voiceAnalyses       VoiceAnalysis[]
  expressionData      ExpressionData[]
  currentInRooms      ConsultationRoom[]   @relation("CurrentRoomStudent")
  // 小程序关系
  posts               Post[]
  comments            Comment[]
  chatSessions        ChatSession[]
  appointments        Appointment[]
  warnings            Warning[]

  @@index([className])
  @@index([facultyId])
  @@index([riskLevel])
  @@map("students")
}

model PsychProfile {
  id                 String   @id @default(uuid())
  studentId          String   @unique @map("student_id")
  adversityQuotient  Int      @map("adversity_quotient")
  emotionalStability Int      @map("emotional_stability")
  socialTendency     Int      @map("social_tendency")
  stressResistance   Int      @map("stress_resistance")
  selfAwareness      Int      @map("self_awareness")
  empathy            Int
  willpower          Int
  adaptability       Int
  overallScore       Int      @map("overall_score")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  student            Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("psych_profiles")
}

model TimelineEvent {
  id          String   @id @default(uuid())
  studentId   String   @map("student_id")
  date        String
  title       String
  description String
  status      String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([status])
  @@map("timeline_events")
}

model Faculty {
  id          String    @id @default(uuid())
  name        String    @unique
  campusX     Float?    @map("campus_x")
  campusY     Float?    @map("campus_y")
  stressIndex Float?    @map("stress_index")
  riskLevel   RiskLevel @default(LOW) @map("risk_level")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  students    Student[]

  @@index([riskLevel])
  @@map("faculties")
}

model Alert {
  id          String    @id @default(uuid())
  studentId   String    @map("student_id")
  type        AlertType
  level       String
  alertTime   DateTime  @map("alert_time")
  source      String
  description String
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([type])
  @@index([level])
  @@index([alertTime])
  @@map("alerts")
}

model WorkOrder {
  id        String          @id @default(uuid())
  studentId String          @map("student_id")
  className String          @map("class_name")
  trigger   String
  riskLevel RiskLevel       @map("risk_level")
  method    String
  counselor String
  status    WorkOrderStatus
  date      DateTime
  detail    String?
  summary   String?
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  student   Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([riskLevel])
  @@index([status])
  @@index([date])
  @@map("work_orders")
}

model InterventionRecord {
  id        String           @id @default(uuid())
  studentId String           @map("student_id")
  date      DateTime
  type      InterventionType
  counselor String
  duration  String
  result    String
  status    String
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([type])
  @@index([date])
  @@index([status])
  @@map("intervention_records")
}

model VRScene {
  id          String      @id @default(uuid())
  name        String      @unique
  description String?
  usageCount  Int         @default(0) @map("usage_count")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  sessions    VRSession[]

  @@map("vr_scenes")
}

model VRSession {
  id            String    @id @default(uuid())
  studentId     String    @map("student_id")
  sceneId       String    @map("scene_id")
  duration      String
  emotionBefore String    @map("emotion_before")
  emotionAfter  String    @map("emotion_after")
  result        Sentiment
  sessionAt     DateTime  @default(now()) @map("session_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  student       Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  scene         VRScene   @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([sceneId])
  @@index([sessionAt])
  @@map("vr_sessions")
}

model Device {
  id           String       @id @default(uuid())
  name         String
  serialNumber String       @unique @map("serial_number")
  type         DeviceType
  model        String?
  status       DeviceStatus
  battery      Int?
  room         String?
  location     String?
  lastActive   String?      @map("last_active")
  lastSync     String?      @map("last_sync")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  roomDevices  RoomDevice[]

  @@index([type])
  @@index([status])
  @@map("devices")
}

model ConsultationRoom {
  id               String       @id @default(uuid())
  name             String
  location         String
  status           RoomStatus
  capacity         Int
  currentStudentId String?      @map("current_student_id")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  currentStudent   Student?     @relation("CurrentRoomStudent", fields: [currentStudentId], references: [id])
  roomDevices      RoomDevice[]

  @@index([status])
  @@index([currentStudentId])
  @@map("consultation_rooms")
}

model RoomDevice {
  id        String           @id @default(uuid())
  roomId    String           @map("room_id")
  deviceId  String           @map("device_id")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  room      ConsultationRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  device    Device           @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([roomId, deviceId])
  @@index([roomId])
  @@index([deviceId])
  @@map("room_devices")
}

model VitalSign {
  id          String   @id @default(uuid())
  studentId   String   @map("student_id")
  timestamp   DateTime
  heartRate   Int      @map("heart_rate")
  hrv         Float?
  gsr         Float?
  stressIndex Int?     @map("stress_index")
  bloodOxygen Float?   @map("blood_oxygen")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([timestamp])
  @@index([studentId, timestamp])
  @@map("vital_signs")
}

model VoiceAnalysis {
  id           String    @id @default(uuid())
  studentId    String    @map("student_id")
  timestamp    DateTime
  sentiment    Sentiment
  tremorIndex  Float     @map("tremor_index")
  emotionLabel String    @map("emotion_label")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  student      Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([timestamp])
  @@index([sentiment])
  @@index([studentId, timestamp])
  @@map("voice_analyses")
}

model ExpressionData {
  id                String   @id @default(uuid())
  studentId         String   @map("student_id")
  timestamp         DateTime
  primaryExpression String   @map("primary_expression")
  anxietyLevel      Float    @map("anxiety_level")
  sadnessLevel      Float    @map("sadness_level")
  angerLevel        Float    @map("anger_level")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  student           Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([timestamp])
  @@index([studentId, timestamp])
  @@map("expression_data")
}

model AIDocument {
  id           String    @id @default(uuid())
  name         String    @unique
  fileSize     String    @map("file_size")
  uploadDate   DateTime  @map("upload_date")
  status       DocStatus
  vectorStatus String    @map("vector_status")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([uploadDate])
  @@map("ai_documents")
}

model AIPromptPreset {
  id         String   @id @default(uuid())
  label      String
  value      String   @unique
  promptText String   @map("prompt_text")
  isActive   Boolean  @default(false) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("ai_prompt_presets")
}

// ============================================
// PsyTwin Pocket 小程序扩展 Schema
// ============================================

model Teacher {
  id             String          @id @default(uuid())
  teacherId      String          @unique @map("teacher_id")
  name           String
  phone          String          @unique
  avatar         String?
  department     String
  title          String
  qualifications String[]
  workStats      Json?           @map("work_stats")
  badges         Json?
  role           String          @default("teacher")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  appointments   Appointment[]
  warnings       Warning[]       @relation("AssignedWarnings")

  @@map("teachers")
}

model Appointment {
  id           String            @id @default(uuid())
  studentId    String            @map("student_id")
  teacherId    String?           @map("teacher_id")
  roomId       String?           @map("room_id")
  type         AppointmentType
  date         DateTime
  timeSlot     String            @map("time_slot")
  status       AppointmentStatus @default(PENDING)
  reason       String?
  cancelReason    String?           @map("cancel_reason")
  meetingLink     String?           @map("meeting_link")
  feedbackScore   Int?              @map("feedback_score")
  feedbackContent String?           @map("feedback_content")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  student      Student           @relation(fields: [studentId], references: [id])
  teacher      Teacher?          @relation(fields: [teacherId], references: [id])

  @@index([studentId])
  @@index([teacherId])
  @@index([date])
  @@index([status])
  @@map("appointments")
}

enum AppointmentType {
  COUNSELING
  VR
  GROUP
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Post {
  id           String     @id @default(uuid())
  authorId     String     @map("author_id")
  content      String
  images       String[]
  location     String?
  isAnonymous  Boolean    @default(false) @map("is_anonymous")
  tags         String[]
  likeCount    Int        @default(0) @map("like_count")
  commentCount Int        @default(0) @map("comment_count")
  riskScore    Float?     @map("risk_score")
  viewCount    Int        @default(0) @map("view_count")
  status       PostStatus @default(ACTIVE)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  author       Student    @relation(fields: [authorId], references: [id])
  comments     Comment[]

  @@index([authorId])
  @@index([createdAt])
  @@map("posts")
}

model Comment {
  id        String        @id @default(uuid())
  postId    String        @map("post_id")
  authorId  String        @map("author_id")
  parentId  String?       @map("parent_id")
  replyToId String?       @map("reply_to_id")
  content   String
  likeCount Int           @default(0) @map("like_count")
  status    CommentStatus @default(ACTIVE)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  post      Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    Student       @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
  @@map("comments")
}

enum PostStatus {
  ACTIVE
  PENDING
  HIDDEN
  DELETED
}

model ChatSession {
  id            String        @id @default(uuid())
  studentId     String        @map("student_id")
  type          SessionType
  title         String
  targetId      String?       @map("target_id")
  targetName    String?       @map("target_name")
  targetAvatar  String?       @map("target_avatar")
  lastMessage   String?       @map("last_message")
  lastMessageAt DateTime?     @map("last_message_at")
  unreadCount   Int           @default(0) @map("unread_count")
  status        SessionStatus @default(ACTIVE)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  messages      ChatMessage[]
  student       Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([status])
  @@index([lastMessageAt])
  @@map("chat_sessions")
}

model ChatMessage {
  id         String        @id @default(uuid())
  sessionId  String        @map("session_id")
  senderId   String        @map("sender_id")
  type       MessageType   @default(TEXT)
  content    String
  seq        Int           @default(0)
  emotionTag String?       @map("emotion_tag")
  cbtCard    Json?         @map("cbt_card")
  status     MessageStatus @default(SENT)
  isRead     Boolean       @default(false) @map("is_read")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")
  session    ChatSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
  @@index([seq])
  @@index([status])
  @@map("chat_messages")
}

enum SessionType {
  AI
  COUNSELOR
}

enum MessageType {
  TEXT
  EMOTION_TAG
  CBT_CARD
  AUDIO
}

model Warning {
  id             String        @id @default(uuid())
  studentId      String        @map("student_id")
  riskLevel      RiskLevel
  riskReason     String        @map("risk_reason")
  triggerSource  String        @map("trigger_source")
  triggerContent String?       @map("trigger_content")
  status         WarningStatus @default(PENDING)
  assignedTo     String?       @map("assigned_to")
  lastAction     Json?         @map("last_action")
  notes          String?
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  student        Student       @relation(fields: [studentId], references: [id])
  counselor      Teacher?      @relation("AssignedWarnings", fields: [assignedTo], references: [id])

  @@index([studentId])
  @@index([riskLevel])
  @@index([status])
  @@index([assignedTo])
  @@map("warnings")
}

enum WarningStatus {
  PENDING
  PROCESSING
  RESOLVED
}

model Schedule {
  id              String   @id @default(uuid())
  teacherId       String   @map("teacher_id")
  dayOfWeek       Int      @map("day_of_week")
  startTime       String   @map("start_time")
  endTime         String   @map("end_time")
  isAvailable     Boolean  @default(true) @map("is_available")
  maxAppointments Int      @default(4) @map("max_appointments")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([teacherId])
  @@index([dayOfWeek])
  @@map("schedules")
}
