generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id                  String                @id @default(uuid())
  name                String
  studentNo           String                @unique @map("student_no")
  className           String                @map("class_name")
  facultyId           String?               @map("faculty_id")
  gender              String?
  birthDate           DateTime?             @map("birth_date")
  mbti                String?
  riskLevel           RiskLevel             @default(LOW) @map("risk_level")
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")
  avatar              String?
  badges              Json?
  lastLoginAt         DateTime?             @map("last_login_at")
  nickname            String?
  passwordHash        String?               @map("password_hash")
  phone               String?               @unique
  role                String                @default("student")
  settings            Json?
  stats               Json?
  status              StudentStatus         @default(ACTIVE)
  joinDate            DateTime?             @map("join_date")
  introduction        String?               // 个人简介
  photos              String[]              // 照片墙
  alerts              Alert[]
  appointments        Appointment[]
  behaviorData        BehaviorData[]
  chatSessions        ChatSession[]
  comments            Comment[]
  currentInRooms      ConsultationRoom[]    @relation("CurrentRoomStudent")
  eegData             EEGData[]
  expressionData      ExpressionData[]
  interventionRecords InterventionRecord[]
  postCollections     PostCollection[]
  postLikes           PostLike[]
  posts               Post[]
  psychProfile        PsychProfile?
  notifications       StudentNotification[]
  faculty             Faculty?              @relation(fields: [facultyId], references: [id])
  timelineEvents      TimelineEvent[]
  vitalSigns          VitalSign[]
  voiceAnalyses       VoiceAnalysis[]
  voiceTranscriptions VoiceTranscription[]
  vrSessions          VRSession[]
  warnings            Warning[]
  workOrders          WorkOrder[]

  @@index([className])
  @@index([facultyId])
  @@index([riskLevel])
  @@map("students")
}

model PsychProfile {
  id                 String   @id @default(uuid())
  studentId          String   @unique @map("student_id")
  adversityQuotient  Int      @map("adversity_quotient")
  emotionalStability Int      @map("emotional_stability")
  socialTendency     Int      @map("social_tendency")
  stressResistance   Int      @map("stress_resistance")
  selfAwareness      Int      @map("self_awareness")
  empathy            Int
  willpower          Int
  adaptability       Int
  overallScore       Int      @map("overall_score")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  student            Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("psych_profiles")
}

model TimelineEvent {
  id          String   @id @default(uuid())
  studentId   String   @map("student_id")
  date        String
  title       String
  description String
  status      String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([status])
  @@map("timeline_events")
}

model Faculty {
  id          String    @id @default(uuid())
  name        String    @unique
  campusX     Float?    @map("campus_x")
  campusY     Float?    @map("campus_y")
  stressIndex Float?    @map("stress_index")
  riskLevel   RiskLevel @default(LOW) @map("risk_level")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  students    Student[]

  @@index([riskLevel])
  @@map("faculties")
}

model Alert {
  id          String    @id @default(uuid())
  studentId   String    @map("student_id")
  type        AlertType
  level       RiskLevel
  alertTime   DateTime  @map("alert_time")
  source      String
  description String
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([type])
  @@index([level])
  @@index([alertTime])
  @@map("alerts")
}

model WorkOrder {
  id        String          @id @default(uuid())
  studentId String          @map("student_id")
  className String          @map("class_name")
  trigger   String
  riskLevel RiskLevel       @map("risk_level")
  method    String
  counselor String
  status    WorkOrderStatus
  date      DateTime
  detail    String?
  summary   String?
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  student   Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([riskLevel])
  @@index([status])
  @@index([date])
  @@map("work_orders")
}

model InterventionRecord {
  id        String              @id @default(uuid())
  studentId String              @map("student_id")
  date      DateTime
  type      InterventionType
  counselor String
  duration  String
  result    String
  status    String
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")
  detail    InterventionDetail?
  student   Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([type])
  @@index([date])
  @@index([status])
  @@map("intervention_records")
}

model InterventionDetail {
  id                  String             @id @default(uuid())
  recordId            String             @unique @map("record_id")
  preMood             String?            @map("pre_mood")
  preAnxietyLevel     Int?               @map("pre_anxiety_level")
  preDepressionLevel  Int?               @map("pre_depression_level")
  preStressLevel      Int?               @map("pre_stress_level")
  mainIssues          String?            @map("main_issues")
  riskLevel           String?            @map("risk_level")
  riskAssessment      String?            @map("risk_assessment")
  sessionContent      String?            @map("session_content")
  techniquesUsed      String[]           @map("techniques_used")
  studentEngagement   String?            @map("student_engagement")
  keyPoints           String?            @map("key_points")
  emotionalChanges    String?            @map("emotional_changes")
  postMood            String?            @map("post_mood")
  postAnxietyLevel    Int?               @map("post_anxiety_level")
  postDepressionLevel Int?               @map("post_depression_level")
  postStressLevel     Int?               @map("post_stress_level")
  improvementScore    Int?               @map("improvement_score")
  breakthroughPoints  String?            @map("breakthrough_points")
  unfinishedIssues    String?            @map("unfinished_issues")
  followUpActions     String?            @map("follow_up_actions")
  nextAppointment     DateTime?          @map("next_appointment")
  referrals           String?            @map("referrals")
  recommendations     String?            @map("recommendations")
  privateNotes        String?            @map("private_notes")
  attachments         String[]           @map("attachments")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  record              InterventionRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@index([recordId])
  @@map("intervention_details")
}

model VRScene {
  id          String      @id @default(uuid())
  name        String      @unique
  description String?
  usageCount  Int         @default(0) @map("usage_count")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  sessions    VRSession[]

  @@map("vr_scenes")
}

model VRSession {
  id            String    @id @default(uuid())
  studentId     String    @map("student_id")
  sceneId       String    @map("scene_id")
  duration      String
  emotionBefore String    @map("emotion_before")
  emotionAfter  String    @map("emotion_after")
  result        Sentiment
  sessionAt     DateTime  @default(now()) @map("session_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  scene         VRScene   @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  student       Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([sceneId])
  @@index([sessionAt])
  @@map("vr_sessions")
}

model Device {
  id           String       @id @default(uuid())
  name         String
  serialNumber String       @unique @map("serial_number")
  type         DeviceType
  model        String?
  status       DeviceStatus
  battery      Int?
  room         String?
  location     String?
  lastActive   String?      @map("last_active")
  lastSync     String?      @map("last_sync")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  roomDevices  RoomDevice[]

  @@index([type])
  @@index([status])
  @@map("devices")
}

model ConsultationRoom {
  id               String       @id @default(uuid())
  name             String
  location         String
  status           RoomStatus
  capacity         Int
  currentStudentId String?      @map("current_student_id")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  currentStudent   Student?     @relation("CurrentRoomStudent", fields: [currentStudentId], references: [id])
  roomDevices      RoomDevice[]

  @@index([status])
  @@index([currentStudentId])
  @@map("consultation_rooms")
}

model RoomDevice {
  id        String           @id @default(uuid())
  roomId    String           @map("room_id")
  deviceId  String           @map("device_id")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  device    Device           @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  room      ConsultationRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, deviceId])
  @@index([roomId])
  @@index([deviceId])
  @@map("room_devices")
}

model VitalSign {
  id          String   @id @default(uuid())
  studentId   String   @map("student_id")
  timestamp   DateTime
  heartRate   Int      @map("heart_rate")
  hrv         Float?
  gsr         Float?
  stressIndex Int?     @map("stress_index")
  bloodOxygen Float?   @map("blood_oxygen")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([timestamp])
  @@index([studentId, timestamp])
  @@map("vital_signs")
}

model VoiceAnalysis {
  id           String    @id @default(uuid())
  studentId    String    @map("student_id")
  timestamp    DateTime
  sentiment    Sentiment
  tremorIndex  Float     @map("tremor_index")
  emotionLabel String    @map("emotion_label")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  student      Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([timestamp])
  @@index([sentiment])
  @@index([studentId, timestamp])
  @@map("voice_analyses")
}

model VoiceTranscription {
  id         String   @id @default(cuid())
  studentId  String   @map("student_id")
  text       String
  timestamp  DateTime
  createdAt  DateTime @default(now()) @map("created_at")
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([timestamp])
  @@map("voice_transcriptions")
}

model ExpressionData {
  id                String   @id @default(uuid())
  studentId         String   @map("student_id")
  timestamp         DateTime
  primaryExpression String   @map("primary_expression")
  anxietyLevel      Float    @map("anxiety_level")
  sadnessLevel      Float    @map("sadness_level")
  angerLevel        Float    @map("anger_level")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  student           Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([timestamp])
  @@index([studentId, timestamp])
  @@map("expression_data")
}

model BehaviorData {
  id              String   @id @default(uuid())
  studentId       String   @map("student_id")
  sessionId       String?  @map("session_id")
  timestamp       DateTime
  interactionFreq Float    @map("interaction_freq")
  handTremor      Float    @map("hand_tremor")
  responseDelay   Float    @map("response_delay")
  avoidanceCount  Int      @map("avoidance_count")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([timestamp])
  @@index([studentId, timestamp])
  @@map("behavior_data")
}

model EEGData {
  id        String   @id @default(uuid())
  studentId String   @map("student_id")
  sessionId String?  @map("session_id")
  timestamp DateTime
  alpha     Float
  beta      Float
  theta     Float
  gamma     Float?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([timestamp])
  @@index([studentId, timestamp])
  @@map("eeg_data")
}

model AIDocument {
  id           String    @id @default(uuid())
  name         String    @unique
  fileSize     String    @map("file_size")
  uploadDate   DateTime  @map("upload_date")
  status       DocStatus
  vectorStatus String    @map("vector_status")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([uploadDate])
  @@map("ai_documents")
}

model AIPromptPreset {
  id         String   @id @default(uuid())
  label      String
  value      String   @unique
  promptText String   @map("prompt_text")
  isActive   Boolean  @default(false) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("ai_prompt_presets")
}

model OpenClawAgent {
  id            String            @id
  name          String?
  role          String?
  emoji         String?
  color         String?
  metadata      Json?
  isOnline      Boolean           @default(false) @map("is_online")
  lastSeenAt    DateTime?         @map("last_seen_at")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  events        OpenClawEvent[]
  assignedReqs  OpenClawRequest[]
  assignedTasks OpenClawTask[]

  @@index([isOnline])
  @@index([lastSeenAt])
  @@map("openclaw_agents")
}

model OpenClawRequest {
  id              String               @id @default(cuid())
  runId           String?              @unique @map("run_id")
  source          String?
  content         String
  state           OpenClawRequestState @default(RECEIVED)
  assignedAgentId String?              @map("assigned_agent_id")
  startedAt       DateTime?            @map("started_at")
  completedAt     DateTime?            @map("completed_at")
  result          String?
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  events          OpenClawEvent[]
  assignedAgent   OpenClawAgent?       @relation(fields: [assignedAgentId], references: [id])
  task            OpenClawTask?

  @@index([runId])
  @@index([state])
  @@index([assignedAgentId])
  @@index([createdAt])
  @@map("openclaw_requests")
}

model OpenClawTask {
  id              String             @id @default(cuid())
  requestId       String             @unique @map("request_id")
  title           String?
  detail          String?
  status          OpenClawTaskStatus @default(PENDING)
  assignedAgentId String?            @map("assigned_agent_id")
  startedAt       DateTime?          @map("started_at")
  completedAt     DateTime?          @map("completed_at")
  result          String?
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  events          OpenClawEvent[]
  assignedAgent   OpenClawAgent?     @relation(fields: [assignedAgentId], references: [id])
  request         OpenClawRequest    @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([assignedAgentId])
  @@index([createdAt])
  @@map("openclaw_tasks")
}

model OpenClawEvent {
  id        String           @id @default(cuid())
  requestId String?          @map("request_id")
  taskId    String?          @map("task_id")
  agentId   String?          @map("agent_id")
  type      String
  state     String?
  message   String
  payload   Json?
  eventTime DateTime         @default(now()) @map("event_time")
  createdAt DateTime         @default(now()) @map("created_at")
  agent     OpenClawAgent?   @relation(fields: [agentId], references: [id])
  request   OpenClawRequest? @relation(fields: [requestId], references: [id])
  task      OpenClawTask?    @relation(fields: [taskId], references: [id])

  @@index([requestId])
  @@index([taskId])
  @@index([agentId])
  @@index([eventTime])
  @@index([type])
  @@map("openclaw_events")
}

model OpenClawConnection {
  id                 String    @id @default("default")
  gatewayUrl         String?   @map("gateway_url")
  connected          Boolean   @default(false)
  lastConnectedAt    DateTime? @map("last_connected_at")
  lastDisconnectedAt DateTime? @map("last_disconnected_at")
  lastError          String?   @map("last_error")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@map("openclaw_connections")
}

model Teacher {
  id             String        @id @default(uuid())
  teacherId      String        @unique @map("teacher_id")
  name           String
  phone          String        @unique
  avatar         String?
  department     String
  title          String
  qualifications String[]
  workStats      Json?         @map("work_stats")
  badges         Json?
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  lastLoginAt    DateTime?     @map("last_login_at")
  passwordHash   String        @map("password_hash")
  status         TeacherStatus @default(ACTIVE)
  role           UserRole      @default(TEACHER)
  nickname       String?
  appointments   Appointment[]
  warnings       Warning[]     @relation("AssignedWarnings")

  @@index([role])
  @@index([status])
  @@map("teachers")
}

model Appointment {
  id              String            @id @default(uuid())
  studentId       String            @map("student_id")
  teacherId       String?           @map("teacher_id")
  roomId          String?           @map("room_id")
  type            AppointmentType
  date            DateTime
  timeSlot        String            @map("time_slot")
  status          AppointmentStatus @default(PENDING)
  reason          String?
  cancelReason    String?           @map("cancel_reason")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  feedbackContent String?           @map("feedback_content")
  feedbackScore   Int?              @map("feedback_score")
  meetingLink     String?           @map("meeting_link")
  student         Student           @relation(fields: [studentId], references: [id])
  teacher         Teacher?          @relation(fields: [teacherId], references: [id])

  @@index([studentId])
  @@index([teacherId])
  @@index([date])
  @@index([status])
  @@map("appointments")
}

model Post {
  id           String           @id @default(uuid())
  authorId     String           @map("author_id")
  content      String
  images       String[]
  location     String?
  isAnonymous  Boolean          @default(false) @map("is_anonymous")
  tags         String[]
  likeCount    Int              @default(0) @map("like_count")
  commentCount Int              @default(0) @map("comment_count")
  riskScore    Float?           @map("risk_score")
  viewCount    Int              @default(0) @map("view_count")
  status       PostStatus       @default(ACTIVE)
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  comments     Comment[]
  collections  PostCollection[]
  likes        PostLike[]
  author       Student          @relation(fields: [authorId], references: [id])

  @@index([authorId])
  @@index([createdAt])
  @@map("posts")
}

model Comment {
  id        String        @id @default(uuid())
  postId    String        @map("post_id")
  authorId  String        @map("author_id")
  parentId  String?       @map("parent_id")
  replyToId String?       @map("reply_to_id")
  content   String
  likeCount Int           @default(0) @map("like_count")
  status    CommentStatus @default(ACTIVE)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  author    Student       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post      Post          @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
  @@map("comments")
}

model PostLike {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  studentId String   @map("student_id")
  createdAt DateTime @default(now()) @map("created_at")
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([postId, studentId])
  @@index([postId])
  @@index([studentId])
  @@index([createdAt])
  @@map("post_likes")
}

model PostCollection {
  id          String   @id @default(uuid())
  postId      String   @map("post_id")
  studentId   String   @map("student_id")
  collectedAt DateTime @default(now()) @map("collected_at")
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([postId, studentId])
  @@index([postId])
  @@index([studentId])
  @@index([collectedAt])
  @@map("post_collections")
}

model StudentNotification {
  id        String           @id @default(uuid())
  studentId String           @map("student_id")
  type      NotificationType
  title     String
  content   String
  actionUrl String?          @map("action_url")
  isRead    Boolean          @default(false) @map("is_read")
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
  @@map("student_notifications")
}

model ChatSession {
  id            String        @id @default(uuid())
  studentId     String        @map("student_id")
  type          SessionType
  title         String
  targetId      String?       @map("target_id")
  targetName    String?       @map("target_name")
  targetAvatar  String?       @map("target_avatar")
  lastMessage   String?       @map("last_message")
  lastMessageAt DateTime?     @map("last_message_at")
  unreadCount   Int           @default(0) @map("unread_count")
  status        SessionStatus @default(ACTIVE)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  messages      ChatMessage[]
  student       Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([status])
  @@index([lastMessageAt])
  @@map("chat_sessions")
}

model ChatMessage {
  id         String        @id @default(uuid())
  sessionId  String        @map("session_id")
  senderId   String        @map("sender_id")
  type       MessageType   @default(TEXT)
  content    String
  seq        Int           @default(0)
  emotionTag String?       @map("emotion_tag")
  cbtCard    Json?         @map("cbt_card")
  status     MessageStatus @default(SENT)
  isRead     Boolean       @default(false) @map("is_read")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")
  session    ChatSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
  @@index([seq])
  @@index([status])
  @@map("chat_messages")
}

model Warning {
  id             String        @id @default(uuid())
  studentId      String        @map("student_id")
  riskLevel      RiskLevel
  riskReason     String        @map("risk_reason")
  triggerSource  String        @map("trigger_source")
  triggerContent String?       @map("trigger_content")
  status         WarningStatus @default(PENDING)
  assignedTo     String?       @map("assigned_to")
  lastAction     Json?         @map("last_action")
  notes          String?
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  counselor      Teacher?      @relation("AssignedWarnings", fields: [assignedTo], references: [id])
  student        Student       @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([riskLevel])
  @@index([status])
  @@index([assignedTo])
  @@map("warnings")
}

model Schedule {
  id              String   @id @default(uuid())
  teacherId       String   @map("teacher_id")
  dayOfWeek       Int      @map("day_of_week")
  startTime       String   @map("start_time")
  endTime         String   @map("end_time")
  isAvailable     Boolean  @default(true) @map("is_available")
  maxAppointments Int      @default(4) @map("max_appointments")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([teacherId])
  @@index([dayOfWeek])
  @@map("schedules")
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  name         String
  passwordHash String     @map("password_hash")
  avatar       String?
  role         UserRole   @default(TEACHER)
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?  @map("last_login_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@index([role])
  @@index([status])
  @@map("users")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  action     String
  resource   String
  resourceId String?  @map("resource_id")
  details    Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model DocumentChunk {
  id         String   @id @default(uuid())
  documentId String   @map("document_id")
  content    String
  embedding  String?
  chunkIndex Int      @map("chunk_index")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([documentId])
  @@index([chunkIndex])
  @@map("document_chunks")
}

model DataSource {
  id         String           @id @default(uuid())
  name       String
  type       DataSourceType
  enabled    Boolean          @default(true)
  config     Json?
  lastSyncAt DateTime?        @map("last_sync_at")
  status     DataSourceStatus @default(DISCONNECTED)
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")
  syncTasks  SyncTask[]

  @@map("data_sources")
}

model SyncTask {
  id           String         @id @default(uuid())
  name         String
  dataSourceId String         @map("data_source_id")
  schedule     String
  enabled      Boolean        @default(true)
  status       SyncTaskStatus @default(IDLE)
  lastSyncAt   DateTime?      @map("last_sync_at")
  nextSyncAt   DateTime?      @map("next_sync_at")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  logs         SyncLog[]
  dataSource   DataSource     @relation(fields: [dataSourceId], references: [id])

  @@map("sync_tasks")
}

model SyncLog {
  id          String        @id @default(uuid())
  taskId      String        @map("task_id")
  startedAt   DateTime      @map("started_at")
  endedAt     DateTime?     @map("ended_at")
  status      SyncLogStatus
  dataSize    Int?          @map("data_size")
  recordCount Int?          @map("record_count")
  errorMsg    String?       @map("error_msg")
  task        SyncTask      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, startedAt])
  @@map("sync_logs")
}

model IPWhitelist {
  id          String   @id @default(uuid())
  ipAddress   String   @map("ip_address")
  description String?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  createdBy   String?  @map("created_by")

  @@index([ipAddress])
  @@map("ip_whitelist")
}

model SystemConfig {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedBy   String?  @map("updated_by")

  @@map("system_config")
}

model NotificationChannel {
  id           String      @id @default(uuid())
  name         String
  type         ChannelType
  enabled      Boolean     @default(false)
  config       Json?
  lastTestedAt DateTime?   @map("last_tested_at")
  testStatus   TestStatus?
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  @@map("notification_channels")
}

model NotificationTemplate {
  id        String       @id @default(uuid())
  name      String
  type      TemplateType
  subject   String?
  content   String
  variables Json?
  updatedAt DateTime     @updatedAt @map("updated_at")
  updatedBy String?      @map("updated_by")

  @@map("notification_templates")
}

model NotificationRule {
  id             String                @id @default(uuid())
  name           String
  enabled        Boolean               @default(true)
  triggerType    TriggerType           @map("trigger_type")
  triggerConfig  Json                  @map("trigger_config")
  channels       String[]
  recipients     Json
  templateId     String?               @map("template_id")
  silentOverride Boolean               @default(false) @map("silent_override")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")
  histories      NotificationHistory[]

  @@map("notification_rules")
}

model NotificationHistory {
  id          String             @id @default(uuid())
  ruleId      String?            @map("rule_id")
  channelType ChannelType        @map("channel_type")
  recipient   String
  title       String
  content     String
  status      NotificationStatus
  errorMsg    String?            @map("error_msg")
  sentAt      DateTime           @default(now()) @map("sent_at")
  deliveredAt DateTime?          @map("delivered_at")
  readAt      DateTime?          @map("read_at")
  rule        NotificationRule?  @relation(fields: [ruleId], references: [id])

  @@index([sentAt])
  @@index([recipient])
  @@map("notification_histories")
}

model SilentHours {
  id          String    @id @default(uuid())
  enabled     Boolean   @default(true)
  startTime   String    @map("start_time")
  endTime     String    @map("end_time")
  exceptLevel RiskLevel @default(HIGH) @map("except_level")

  @@map("silent_hours")
}

