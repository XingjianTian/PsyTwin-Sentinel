# ==========================================
# 数据库配置（必需）
# ==========================================
POSTGRES_USER=psytwin
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=psytwin_sentinel
POSTGRES_PORT=5432
DATABASE_URL="postgresql://psytwin:your_password_here@localhost:5432/psytwin_sentinel?schema=public"

# ==========================================
# AI 服务配置（可选，但推荐配置以获得完整功能）
# ==========================================
# 阿里云 Dashscope API Key（用于 Qwen 大模型）
# 获取地址：https://dashscope.aliyun.com/
DASHSCOPE_API_KEY="your-dashscope-api-key-here"

# OpenAI API Key（可选，用于嵌入模型）
# 如果不配置，将使用文本搜索替代向量搜索
OPENAI_API_KEY="your-openai-api-key-here"

# ==========================================
# 应用配置（可选）
# ==========================================
# 应用名称和版本
NEXT_PUBLIC_APP_NAME="PsyTwin Sentinel"
NEXT_PUBLIC_APP_VERSION="1.0.0"
